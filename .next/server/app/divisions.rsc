0:["3p5IQtbjELB91vRXCkkkI",[[["",{"children":["divisions",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["divisions",{"children":["__PAGE__",{},[["$L1",["$","main",null,{"className":"divisions","children":[["$","div",null,{"className":"hero","children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/Divisions-e1727869777541.jpg","alt":"","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"tint-overlay","style":{"backgroundColor":"#3F3F3F"}}],["$","h1",null,{"className":"hero-text","style":{"color":"#FFFFFF"},"children":"Super Prime Construction"}]]}],["$","div",null,{"className":"block-1 pad-h pv-80","children":[["$","div",null,{"className":"top","children":[["$","h2",null,{"children":"Our Divisions"}],["$","div",null,{"className":"brygada-font","children":[["$","h3",null,{"children":"Through Knowles’ dedicated specialist divisions and expansive range of in-house skills we have cultivated an ability to continuously deliver outstanding projects to the highest of specifications and standards."}],[["$","p","0",{"children":"We have extensive experience of working on a broad range of super-prime residential projects, both historic and contemporary, with a project portfolio including redeveloping London townhouses and villas, restoring listed country homes, and the complete creation of major new private residences and country estates."}]]]}]]}],["$","$L3",null,{}]]}],["$","div",null,{"className":"block-2 pad-h pv-80","children":[["$","div",null,{"className":"top","children":[["$","div",null,{"children":[["$","h4",null,{"children":"An Approach Like No Other"}],["$","div",null,{"children":[["$","p",null,{"children":"Where other contractors might shy away from a project, Knowles steps forward and thrives. And as a result, we have become the trusted go-to partner for architects, quantity surveyors, professional teams and private clients alike."}],["$","p",null,{"children":"Our commitment to in-house management on every project guarantees a consistent approach and the best experience for our clients; from the management of structural design, to the coordination and management of all consultant and subcontractor design packages. As Principal Contractor, Knowles provides a comprehensive construction service to clients and professional teams, taking a project from concept to completion."}],["$","p",null,{"children":"We retain a greater control over on-site operations without the need to rely on others, which also provides an optimum programme duration by overlapping construction phases where possible. And our maintenance aftercare provision is the final touch to our world-renowned service."}],["$","p",null,{"children":"It is our aim to exceed expectations at every point, regardless of the complexity of the project. This excellence is the foundation upon which Knowles is built."}]]}]]}],["$","$L4",null,{"className":"button","href":"/about#team","children":"Meet the Team"}]]}],["$","div",null,{"style":{"position":"relative","aspectRatio":"973/648"},"children":["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/KNTY-08902-e1727869994984.jpg","alt":"","fill":true,"style":{"objectFit":"cover"}}]}]]}]]}]],null],null]},["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","divisions","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}],null]},[["$","html",null,{"lang":"en-US","className":"__variable_acc748 __variable_f367f3","children":["$","body",null,{"children":[["$","$L7",null,{}],["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound