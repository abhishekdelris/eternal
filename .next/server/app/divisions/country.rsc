0:["3p5IQtbjELB91vRXCkkkI",[[["",{"children":["divisions",{"children":[["slug","country","d"],{"children":["__PAGE__?{\"slug\":\"country\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["divisions",{"children":[["slug","country","d"],{"children":["__PAGE__",{},[["$L1",["$","main",null,{"className":"single-divisions","children":[["$","div",null,{"className":"hero","children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/Country-e1727868371153.jpg","alt":"Country","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"tint-overlay","style":{"backgroundColor":"#3F3F3F"}}],["$","h1",null,{"className":"hero-text","style":{"color":"#FFFFFF"},"children":"Country"}]]}],["$","div",null,{"className":"block-1 pad-h pv-80","children":[["$","div",null,{"className":"left","children":[["$","h4",null,{"children":"Our renewed service in the Home Counties"}],["$","div",null,{"children":[["$","h3",null,{"children":"Notable by experience and recognised by our exceptional portfolio, Knowles Country operates in all key regions outside of the M25 – from the Cotswolds and Wiltshire to Surrey and Hertfordshire. Delivering some of the finest private residences and Country estates, both new and historic, Knowles Country is an extension and partner of our renowned London service, with the same experience, principles and dynamism applied throughout."}],["$","p",null,{"children":" "}],[["$","p","0",{"children":"We’ve built a team with decades of experience and an intimate understanding of the country’s rich architectural heritage, local materials, artisan trades and construction techniques, led by Mark Haslam, Knowles Country Operations Director."}],["$","p","1",{"children":"Our portfolio is held with the utmost discretion but has ranged from legacy projects completed over many years due to size and complexity, to fast-tracked accelerated work to renovate the most sensitive of homes or add ancillary buildings to a property."}],["$","p","2",{"children":"Knowles Country work in close collaboration with our Knowles Structures division, as the work often runs alongside each other for maximum output and results."}],["$","p","3",{"children":"Please note, many of our Country projects are under strict non-Disclosure Agreements."}]]]}],["$","$L3",null,{"sections":[{"title":"Private Residences","content":"Knowles has had the privilege of delivering some of the country’s most exciting and prestigious new-build private residences, encompassing a diverse array of architectural styles. From modern farmhouses to classically inspired Palladian residences, each project showcases our commitment to excellence. Our dedication to quality ensures that every estate blends harmoniously with its natural surroundings while meeting the bespoke requirements of our clients."},{"title":"Estate Works","content":"Our expertise extends beyond the main residences of country estates to encompass comprehensive estate works. This includes the construction of access roads, service buildings, leisure facilities, energy centres, staff accommodations, intricate hard landscaping, and even lakes and golf courses. We ensure that the estate’s infrastructure supports both functionality and aesthetics – tailored to enhance its overall value and usability."},{"title":"Refurbishment and Renovation","content":"Knowles Country has extensive experience in renovating and refurbishing country houses, historic buildings, and Grade-listed residences. With decades of expertise, our team possesses a unique and advanced understanding of the country’s rich architectural heritage, local materials, artisan trades, and traditional construction techniques. We approach each project with the utmost sensitivity, ensuring the integrity and legacy of these esteemed properties are preserved for future generations."},{"title":"Key Services","list":["Private Estates","Country Houses","Historic & Listed Buildings","Estate & Leisure Facilities","Specialist Restoration","Landscaping","Refurbishment and Renovation","Estate Works"]}]}]]}],["$","div",null,{"className":"right","style":{"position":"relative","aspectRatio":"899/1080"},"children":["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/Country-e1727868371153.jpg","alt":"","fill":true,"style":{"objectFit":"cover"}}]}]]}],["$","div",null,{"className":"related-projects pv-80","children":[["$","div",null,{"className":"top pad-h mb-80","children":[["$","h2",null,{"children":"Related Projects"}],["$","$L4",null,{"className":"button","href":"/projects","children":"More Projects"}]]}],["$","div",null,{"className":"divisions-grid pad-h","children":[["$","div","Cotswolds Manor House-0",{"className":"projects-thumb","children":[["$","div",null,{"className":"image","style":{"position":"relative"},"children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2025/06/langston-website.jpg.webp","alt":"Cotswolds Manor House","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"overlay","style":{"backgroundColor":"#004a39"}}]]}],["$","div",null,{"className":"details","children":[["$","div",null,{"children":"Cotswolds Manor House"}],["$","div",null,{"className":"dark-grey","children":"Country"}]]}]]}],["$","div","Private Country House, Hertfordshire-1",{"className":"projects-thumb","children":[["$","div",null,{"className":"image","style":{"position":"relative"},"children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2025/06/Overture-Manor-Project-Image-scaled.jpg.webp","alt":"Private Country House, Hertfordshire","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"overlay","style":{"backgroundColor":"#004a39"}}]]}],["$","div",null,{"className":"details","children":[["$","div",null,{"children":"Private Country House, Hertfordshire"}],["$","div",null,{"className":"dark-grey","children":"Country"}]]}]]}],["$","div","Private Country House, Oxfordshire-2",{"className":"projects-thumb","children":[