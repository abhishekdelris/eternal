0:["3p5IQtbjELB91vRXCkkkI",[[["",{"children":["divisions",{"children":[["slug","london","d"],{"children":["__PAGE__?{\"slug\":\"london\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["divisions",{"children":[["slug","london","d"],{"children":["__PAGE__",{},[["$L1",["$","main",null,{"className":"single-divisions","children":[["$","div",null,{"className":"hero","children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/London-e1727867652193.jpg","alt":"London","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"tint-overlay","style":{"backgroundColor":"#3F3F3F"}}],["$","h1",null,{"className":"hero-text","style":{"color":"#FFFFFF"},"children":"London"}]]}],["$","div",null,{"className":"block-1 pad-h pv-80","children":[["$","div",null,{"className":"left","children":[["$","h4",null,{"children":"Expertly Delivered Construction"}],["$","div",null,{"children":[["$","h3",null,{"children":"The Knowles London team has operated within the super-prime sector for over three decades, earning a renowned reputation for delivering exceptional work across London and within the borough estates. Based at our head office in Marylebone, Knowles London provides a fully comprehensive service, from planning assistance to fit-out and beyond."}],["$","p",null,{"children":" "}],[["$","p","0",{"children":"Knowles London acts as Principal Contractor, taking responsibility for the overarching delivery of all projects in London – from commencement to client handover. Throughout the project lifecycle, we work closely with other Knowles divisions, including Structures, Special Projects, and Aftercare, to ensure maximum output and seamless delivery. Our goal is to exceed expectations at every corner, whether constructing a new structure within an existing shell or completing a full new-build project. Over the years, we have worked on a diverse range of property styles, including London townhouses, Palladian Regency villas, penthouses, and listed buildings."}],["$","p","1",{"children":"Knowles London collaborates closely with the Knowles Structures division daily, with works often running concurrently in a strategic approach that maximises efficiency and results. Our comprehensive range of construction services allows us to deliver projects from concept to completion. This includes initial planning, viability assessments, PCSA, and enabling works, as well as the complete management of the principal contract and coordination of subcontractors and specialist trades."}],["$","p","2",{"children":"Our team’s enthusiasm and dynamism stem from extensive experience, fostering confidence in our in-house capabilities. This reduces our reliance on subcontractors compared to competitors, enabling us to be more responsive, innovative, and agile. Many of our projects come from repeat clients, referrals, and ongoing collaborations with professional teams – a testament to the trust and satisfaction we consistently deliver."}]]]}],["$","$L3",null,{"sections":[{"title":"Basements","content":"Knowles is proud to have a dedicated Structures Division that coordinates the complex basement and superstructure work for every Knowles project. Their unparalleled experience and expertise make them the trusted, go-to team for managing this level of intricate work within super-prime residences."},{"title":"Shell & Core","content":"We are renowned for our expertise in delivering shell and core projects across London. This approach provides significant benefits, allowing a project to commence by laying vital foundations while finalising the internal design and aesthetics. It ensures the project stays on track and aligned with the programme."},{"title":"Fit-Out","content":"To ensure seamless continuity of our services, when it comes to the fit-out we draw on our extensive network of interior designers, specialist trades, and preferred suppliers to deliver the perfect finish to every project. During the final stage, Knowles oversees all floor and wall finishes, coordinates bespoke joinery and carpentry packages, manages lighting and AV installations, and accommodates any other unique requests that a client may have."},{"title":"Key Services","list":["New Build","Basements","Shell & Core","Refurbishment","Fine and Specialist Finishes","Demolition","Façade Retention"]}]}]]}],["$","div",null,{"className":"right","style":{"position":"relative","aspectRatio":"899/1080"},"children":["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/London-e1727867652193.jpg","alt":"","fill":true,"style":{"objectFit":"cover"}}]}]]}],["$","div",null,{"className":"related-projects pv-80","children":[["$","div",null,{"className":"top pad-h mb-80","children":[["$","h2",null,{"children":"Related Projects"}],["$","$L4",null,{"className":"button","href":"/projects","children":"More Projects"}]]}],["$","div",null,{"className":"divisions-grid pad-h","children":[["$","$L4","warwick-avenue",{"className":"projects-thumb","href":"/projects/warwick-avenue","children":[["$","div",null,{"className":"image","style":{"position":"relative"},"children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-196-scaled.jpg.webp","alt":"Warwick Avenue W9","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"overlay","style":{"backgroundColor":"#e0ded9"}}]]}],["$","div",null,{"className":"details","children":[["$","div",null,{"children":"Warwick Avenue W9"}],["$","div",null,{"className":"dark-grey","children":"London"}]]}]]}],["$","div","Pimlico Townhouse-1",{"className":"projects-thumb","children":[["$","div",null,{"className":"image","style":{"position":"relative"},"children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2026/05/Chester-Landscape.jpg.webp","alt":"Pimlico Townhouse","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"overlay","style":{"backgroundColor":"#e0ded9"}}]]}],["$","div",null,{"className":"det