0:["3p5IQtbjELB91vRXCkkkI",[[["",{"children":["divisions",{"children":[["slug","special-projects","d"],{"children":["__PAGE__?{\"slug\":\"special-projects\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["divisions",{"children":[["slug","special-projects","d"],{"children":["__PAGE__",{},[["$L1",["$","main",null,{"className":"single-divisions","children":[["$","div",null,{"className":"hero","children":[["$","$L2",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/Will-Pryce-Avenue-Road-_DSF3685-FL-copy-WEB.jpg.webp","alt":"Special Projects","fill":true,"style":{"objectFit":"cover"}}],["$","div",null,{"className":"tint-overlay","style":{"backgroundColor":"#3F3F3F"}}],["$","h1",null,{"className":"hero-text","style":{"color":"#FFFFFF"},"children":"Special Projects"}]]}],["$","div",null,{"className":"block-1 pad-h pv-80","children":[["$","div",null,{"className":"left","children":[["$","h4",null,{"children":"Providing a white-glove, bespoke service"}],["$","div",null,{"children":[["$","h3",null,{"children":"Created to service new and existing Clients with their unique property needs, Knowles Special Projects division provides an efficient white-glove, bespoke service for projects which are smaller in scale but intricate in their complexity, attention to detail or value."}],["$","p",null,{"children":" "}],[["$","p","0",{"children":"Knowles Special Projects Division, supports Clients, professional teams and property managers with a range of works from one-off deliverables such as room refurbishments and reconfigurations to minor structural alterations and special installations. Our Aftercare offering within the special projects division continues to provide ongoing planned and preventative maintenance services and property management support to our valued Clients."}],["$","p","1",{"children":"Our Special Projects division is established using lean principles and a streamlined, fast-track approach compared with traditional projects which affords our clients reduced lead-in time and commencement flexibility. The special projects team are reactive and dynamic in accommodating bespoke arrangements and individual Client needs."}],["$","p","2",{"children":"Knowles Special Projects division works in close collaboration with our clients and their lead design consultants on all aspects of the special project, to ensure works can be achieved in optimum timescales with flexible unrestrictive contract terms."}],["$","p","3",{"children":"With the ability to draw on the expertise from the wider Knowles group network, special projects have the ability to be combined with other division offerings at Knowles including AUTO CAVE."}]]]}],["$","$L3",null,{"sections":[{"title":"Special Works","content":"When clients require a smaller scope of works, whether it is refurbishing a bathroom, redesigning an entire floor of their home, or retiling of a spa space to give it a new lease on life, Knowles Special Projects will undertake the project utilising the most appropriate and relevant resource from our specialist construction team. Following an agreed design, our team have the ability to deliver the project in a fast-tracked manner, often at the request of our clients, to minimise disruption and offer an element of discretion and care working within occupied homes."},{"title":"Aftercare and Preventative Maintenance","content":"As part of our Special Projects division, Knowles’ Aftercare Service is available to ensure that we can provide clients with continued planned and preventative maintenance support once they have occupied their new property. Serviced via our mobile team, our comprehensive offering covers all eventualities from resolving practical problems that may arise, to the arrangement of annual property specific maintenance servicing and ongoing general property support."},{"title":"Key Services","list":["Tailored Refurbishments","Aftercare & Preventative Maintenance","Bespoke Property Services","Specialist Artisan requirem