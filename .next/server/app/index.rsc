0:["3p5IQtbjELB91vRXCkkkI",[[["",{"children":["__PAGE__",{}]},"$undefined","$undefined",true],["",{"children":["__PAGE__",{},[["$L1",["$","main",null,{"className":"homepage","children":[["$","$L2",null,{}],["$","div",null,{"className":"text-image pad-h pv-80","children":[["$","div","0",{"children":[["$","$L3",null,{"children":[["$","h3",null,{"children":"For over 30 years, Knowles has stood for building excellence in the UK's super-prime construction industry. Working on complex building projects in London and the Home Counties, our reputation speaks for itself."}],[["$","p","0",{"children":"We have extensive experience working on a broad range of private residential projects, both historic and contemporary, with a project portfolio including London townhouses and villas, restoring listed country homes, and the creation of major new private residences and country estates. We offer specialist skills in construction, structural and heritage projects, with our in-house Structures division handling all shell, core and subterranean works."}],["$","p","1",{"children":"Knowles is a family-run construction business, founded by Robin Knowles. Our headquarters in Marylebone, London coordinates our 250 strong workforce, across London and the Home Counties, with all members of the Knowles team sharing our commitment to delivering a service for our clients that is like no other."}]]]}],["$","$L3",null,{"className":"image-wrap","children":["$","$L4",null,{"src":"https://knowles.uk.com/wp-content/uploads/2024/10/Divisions-option2-scaled-e1727880509323.jpg","alt":"","fill":true,"imgClassName":"full-bleed-image","sizes":"(max-width: 768px) 100vw, 50vw"}]}]]}],["$","div","1",{"children":[["$","$L3",null,{"className":"image-wrap","children":["$","$L4",null,{"src":"https://knowles.uk.com/wp-content/uploads/2026/02/55ar.jpg.webp","alt":"","fill":true,"imgClassName":"full-bleed-image","sizes":"(max-width: 768px) 100vw, 50vw"}]}],["$","$L3",null,{"children":[["$","h3",null,{"children":"We have become the trusted go-to partner for architects, quantity surveyors, professional teams and private clients alike. Our focus on retaining in-house excellence is what sets us apart. Our ethos allows us to be dynamic, agile and self-sufficient, by keeping trades in house, we have the ability to deliver and manage work directly; a service unique in this industry."}],[["$","p","0",{"children":"Our commitment to in-house management guarantees a consistent approach and the best experience for our clients; from the management of structural design, to the coordination of all consultant and subcontractor packages. As Principal Contractor, Knowles provides a comprehensive construction service, taking a project from concept to completion."}],["$","p","1",{"children":"It is our aim to exceed expectations at every point, regardless of the complexity of the project. This excellence is the foundation upon which Knowles is built."}]]]}]]}]]}],["$","$L5",null,{}],["$","$L6",null,{}],["$","section",null,{"className":"latest-news pt-80 pad-h","children":[["$","$L3",null,{"as":"div","className":"top pb-80 ourservice","children":[["$","h2",null,{"children":"Latest News"}],["$","$L7",null,{"className":"button desktop-only","href":"/news","children":"More News"}]]}],["$","div",null,{"className":"news-grid","children":[["$","$L3","primeresi-23-5mn-price-tag-for-shh-designed-little-venice-villa",{"as":"div","children":["$","$L7",null,{"href":"/news/primeresi-23-5mn-price-tag-for-shh-designed-little-venice-villa","className":"news-card news-thumb","children":[["$","div",null,{"className":"image","children":[["$","$L4",null,{"src":"https://knowles.uk.com/wp-content/uploads/2026/05/Warwick-v2.gif.webp","alt":"PrimeResi: £23.5mn price tag for SHH-designed Little Venice villa","fill":true,"imgClassName":"full-bleed-image","sizes":"(max-width: 768px) 50vw, 25vw"}],["$","div",null,{"className":"overlay"}],["$","div",null,{"className":"read-link brygada-font uppercase","children":"Read"}]]}],