0:["3p5IQtbjELB91vRXCkkkI",[[["",{"children":["reviews",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["reviews",{"children":["__PAGE__",{},[["$L1",[["$","$L2",null,{"theme":"black"}],["$","div",null,{"className":"reviewpage","children":["$","main",null,{"children":[["$","section",null,{"className":"intro","children":[["$","p",null,{"className":"intro__label","children":"Client Testimonials"}],["$","p",null,{"className":"intro__text","children":"At the heart of our operation lies an obsession with doing things right from the start. Please see below, a selection of reviews of what our clients and professional partners say about working with us."}]]}],["$","$L3",null,{}],["$","section",null,{"className":"testimonial-grid","children":[["$","$L4","James Henderson",{"testimonial":{"name":"James Henderson","role":"Architect","quote":"I've finished a few projects — large refurbishments, as an architect — with Hawksmoor. Consistently an excellent standard of work, and a pleasure to work with the team.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/65f97fc01a9ab12796fda91d_65a929cc7698352431545e54_hawksmoor-construction-Cleveland-Gardens-for-builder-44-p-1080.jpg","projectHref":"/projects/barnes"},"index":0}],["$","$L4","Neil Dixon",{"testimonial":{"name":"Neil Dixon","role":"Client","quote":"We hired Paul and team to carry out a back-to-brickwork renovation of our Victorian house in Barnes. They were consummate professionals throughout — both super responsive and receptive to our requests. The craftsmanship and finish were first class. We would highly recommend them.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/65f97fc9ac5d0452d102e5fe_65e5da87d62ef178dbc54a93_hawksmoor-construction-barnes-2-main-p-1080.jpg","projectHref":"/projects/barnes-2"},"index":1}],["$","$L4","Amelia Granville",{"testimonial":{"name":"Amelia Granville","role":"Extension & Internal Refurbishment","quote":"Hawksmoor Construction are simply the best. Professional, and the quality of their work is exceptional. They go out of their way to make things work for the client — I actually missed them when the job was finished. I wouldn't hesitate to recommend them.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/65dc866ba8f48db92f0e0136_651d53a88a212676e4cac542_Hawksmoor-construction-new-builds-notting-hill-9-p-1600.jpg","projectHref":"/projects/notting-hill"},"index":2}],["$","$L4","Charles Baigler",{"testimonial":{"name":"Charles Baigler","role":"Extension & Internal Refurbishment","quote":"Paul and the team did an incredible job on my kitchen extension. I'd highly recommend them and will use them again. Honest, high quality and professional.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6213b4aff2aee72297b736dc_Hawksmoor-construction-new-builds-london-10.jpg","projectHref":"/projects/wrentham-avenue"},"index":3}],["$","$L4","Laura Sanjuan",{"testimonial":{"name":"Laura Sanjuan","role":"Architect & Director at SODA Studio","quote":"I recently worked with Hawksmoor on the refurbishment of a residential property in London. Paul was honest, reliable, responsive and professional, with a great eye for detail. The project is complete, and I couldn't be happier.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/63d7e4b38566b26051f344fd_6362d68d8506b5ac164581c4_Hawksmoor-construction-new-builds-london-the-chase-8-p-1600.jpeg","projectHref":"/projects/clapham"},"index":4}],["$","$L4","Kelly Lee",{"testimonial":{"name":"Kelly Lee","role":"Extension & Internal Reconfiguration","quote":"What can I say — they were simply a joy to have around. Completing the project on time and to a high standard has been nothing short of amazing. It was always exciting to see things go from on-site brainstorming sessions to completion.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6051c3da65cd6928a08b6e42_the-maltings-hawksmoor-construction-maltings-building-construction-london-project-1-p-2600.jpeg","projectHref":"/projects/the-maltings"},"index":5}],["$","$L4","Pereen d'Avoine",{"testimonial":{"name":"Pereen d'Avoine","role":"Architect","quote":"My architectural practice, Russian For Fish, has worked with Hawksmoor in both a professional capacity and as a client. They are a dream to work with — we cannot recommend them highly enough.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6054c43df4474dd93b1d07b5_hawksmoor-construction-st-Saviours-building-construction-london-project-1.jpg","projectHref":"/projects/st-saviours-road"},"index":6}],["$","$L4","Lucie Branczik",{"testimonial":{"name":"Lucie Branczik","role":"Extension & Internal Refurbishment","quote":"Hawksmoor are excellent builders. Their on-site team are helpful and friendly, and they have good after-care service. We are incredibly happy with our refurbished home. Would definitely recommend.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6054c4488bf9bc464aedb440_hawksmoor-construction-st-Saviours-building-construction-london-project-2.jpg","projectHref":"/projects/st-saviours-road"},"index":7}],["$","$L4","Nick Varey",{"testimonial":{"name":"Nick Varey","role":"Architect","quote":"From the outset I found Paul to be a great communicator, and his approach to the project was professional. The quality of the work on site is very high, with great attention paid to ensuring the vision of the architect and client is delivered as planned.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6054bb3887acc78533a4bd45_hawksmoor-construction-projects-london-kitchen.jpg","projectHref":"/projects/the-maltings"},"index":8}],["$","$L4","Alex Rider Stirland",{"testimonial":{"name":"Alex Rider Stirland","role":"Architect","quote":"Rider Stirland Architects have worked with Paul and his fantastic team on a number of complex residential projects. Their professional approach, hard work and communication allow Hawksmoor to deliver to a very high standard.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6051c35b13547b23539b3d62_tonsley-hill-hawksmoor-construction-tonsley-building-construction-london-project-p-2600.jpeg","projectHref":"/projects/tonsley-hill"},"index":9}],["$","$L4","Hannah Smith",{"testimonial":{"name":"Hannah Smith","role":"Loft Conversion & Refurbishment","quote":"The team have just completed a fantastic loft conversion and renovation of our Wandsworth Victorian home, and we are thrilled with the results. Communication has always been top notch and open, and the quality of the finish is impressive and beautiful.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6051cbd74c08bdf2892d53ec_smeaton-road-Hawksmoor-construction-Smeaton-road-p-2600.jpeg","projectHref":"/projects/smeaton-road"},"index":10}],["$","$L4","Susan Rumbold",{"testimonial":{"name":"Susan Rumbold","role":"Director at Tessuto Interiors","quote":"We have worked with Hawksmoor on three projects in the past year. With Hawksmoor, we are assured that all aspects of the job will run smoothly, finished to the highest order and on time if not earlier than projected.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6051ce4f76d2b6ad1e37580f_chelsea-habour-hawksmoor-construction-chelsea-p-2600.jpeg","projectHref":"/projects/chelsea-harbour"},"index":11}],["$","$L4","Valeria Ruzzon",{"testimonial":{"name":"Valeria Ruzzon","role":"Side Return & Full Refurbishment","quote":"From the very first telephone conversation Paul was responsive, proactive and understanding. His team is a credit to him — polite, pleasant, engaging and respectful. I wouldn't hesitate to recommend.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6051cac97d418b38bd1abead_comyn-road-hawksmoor-construction-battersea-p-2600.jpeg","projectHref":"#"},"index":12}],["$","$L4","Rachel Alexander",{"testimonial":{"name":"Rachel Alexander","role":"Side Return & Rear Extension","quote":"Paul and his team did a brilliant job with our kitchen extension. Paul really takes pride in his work and made sure we were completely happy with everything. His customer service is exemplary and communication was excellent throughout.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/5e9d9ce3e90ee765465468ab_Hawksmoor-construction-First-Avenue-3.jpg","projectHref":"#"},"index":13}],["$","$L4","Steve Newton",{"testimonial":{"name":"Steve Newton","role":"Senior Designer at Tessuto Interiors","quote":"Paul and Hawksmoor Construction have worked on three projects for us in the past year. Very knowledgeable, approachable and fair — this teamwork is only achievable working with contractors who are respectful and communicate well.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6051c95c67295f7a5b275de9_addison-garden-hawksmoor-construction-london-p-1600.jpeg","projectHref":"#"},"index":14}],["$","$L4","Tanya Rainsley",{"testimonial":{"name":"Tanya Rainsley","role":"Architect","quote":"I have worked with Hawksmoor a number of times over the last few years, for my own and clients' projects. They are easy to work with, fair, efficient, and have a high standard of finish. I would recommend them highly.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/6051c8697d76f566c712b23d_first-avaneue-Hawksmoor-construction-First-Avenue-2-p-2600.jpeg","projectHref":"#"},"index":15}],["$","$L4","Gemma Lippiat",{"testimonial":{"name":"Gemma Lippiat","role":"3-Storey Extension & Loft Conversion","quote":"Hawksmoor have just finished a loft conversion and complete refurbishment of our Victorian terrace house. Paul was constantly calm, reassuring and professional. Even our neighbours commented on how polite and accommodating the team were.","image":"https://cdn.prod.website-files.com/5e8f15ba6ffc693d7526e1ad/600fe66928533a06bd2bb061_hawksmoor-construction-tonsley-building-construction-london-project-7.jpg","projectHref":"/projects/tonsley-hill"},"index":16}]]}]]}]}]]],null],null]},["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","reviews","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}],null]},[["$","html",null,{"lang":"en-US","className":"__variable_acc748 __variable_f367f3","children":["$","body",null,{"children":[["$","$L2",null,{}],["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":"404"}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]],"notFoundStyles":[],"styles":null}],["$","$L7",null,{}]]}]}],null],null],[[["$","lin