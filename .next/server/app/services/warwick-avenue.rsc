ren":[["$","li","0",{"children":"Strip out and refurbishment"}],["$","li","1",{"children":"M&E Installation"}],["$","li","2",{"children":"Reconfiguration of Lower Ground Floor"}],["$","li","3",{"children":"High-specification bespoke finishes"}],["$","li","4",{"children":"Landscaping works"}]]}]]}]]}],["$","div",null,{"className":"pd-intro__description","children":[["$","p","0",{"children":"Located on the coveted Warwick Avenue, Knowles acted as Principal Contractor for the newly reimagined elegant Grade II listed villa in Little Venice. The project, designed by SHH, involved a full strip out and sympathetic refurbishment of the five-storey property, carefully preserving the property's historic architectural details while creating a luxury home for dynamic contemporary living."}],["$","p","1",{"children":"Totalling over 7,700 sq/ft, the property maintains exceptional attention to detail with specialist glazed doors, a newly restored striking central stone cantilevered staircase and original fibrous mouldings, and bespoke joinery, with neutral, warm undertones and metallic details throughout. New M&E installation, AV and BMS systems, lighting control, and air conditioning were introduced and are discreetly housed within the garden."}],["$","p","2",{"children":"Designed with calmness in mind, the subterranean wellness suite, inspired by the dark waters of the canal offers a 15-meter pool, mosaic tiled hammam and gym with wall lined in dark porcelain tiles bringing a sense of tranquillity to the home."}],["$","p","3",{"children":"Externally, hard and soft landscaping were undertaken to the front and rear incorporating natural stone paving and extensive planting of shrubs and trees as well as the addition of a roof terrace overlooking Maida Vale."}],["$","p","4",{"children":"It's a residence where elegance and craftsmanship meet everyday living, breathing new life into this refined cosmopolitan property."}]]}],["$","div",null,{"className":"pd-testimonial","children":[["$","h4",null,{"children":"Testimonials"}],["$","blockquote",null,{"className":"pd-testimonial__quote","children":["“","Warwick Avenue is a prime example of Knowles' reputation for expertise and attention to detail when delivering super-prime fit-out works. By managing all elements in house from bespoke finishes and landscaping, we're able to maintain the highest standards with unparalleled efficiency and precision.","”"]}],["$","p",null,{"className":"pd-testimonial__author","children":"Mark Hailey, Construction Director, Knowles"}]]}]]}],["$","div",null,{"className":"pd-intro__right","children":[["$","div","0",{"className":"pd-intro__side-image","children":["$","$L3",null,{"src":"https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-020-scaled.jpg","alt":"","fill":true,"sizes":"(max-width: 768px) 100vw, 40vw","className":"pd-intro__side-image-img"}]}],["$","div","1",{"className":"pd-intro__side-image","children":["$","$L3",null,{"src":"https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-126-scaled.jpg","alt":"","fill":true,"sizes":"(max-width: 768px) 100vw, 40vw","className":"pd-intro__side-image-img"}]}],["$","div","2",{"className":"pd-intro__side-image","children":["$","$L3",null,{"src":"https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-126-scaled.jpg","alt":"","fill":true,"sizes":"(max-width: 768px) 100vw, 40vw","className":"pd-intro__side-image-img"}]}]]}]]}],["$","section",null,{"className":"pd-gallery","children":["$","$L4",null,{"images":["https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-149-scaled.jpg.webp","https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-149-scaled.jpg.webp","https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-149-scaled.jpg.webp","https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-149-scaled.jpg.webp","https://knowles.uk.com/wp-content/uploads/2026/05/20260128-WarwickAv-149-scaled.jpg.webp"]}]}],["$","section",null,